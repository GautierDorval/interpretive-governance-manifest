      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Valeur dépendante du temps, du vendeur, de la région, du stock ou des promotions, pouvant changer sans modifier l’identité du produit.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/ctic"
      },
      "name": "Variable dynamique"
    },

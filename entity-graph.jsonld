    {
      "@id": "https://gautierdorval.com/doctrine/gouvernance-memoire/#definedterm",
      "@type": "DefinedTerm",
      "alternateName": [
        "Memory governance",
        "Memory Governance"
      ],
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Extension doctrinale appliquée aux systèmes stateful (RAG avancé, agents à mémoire persistée). Elle impose typage des objets mémoire, traçabilité, intégrité temporelle, consolidation gouvernée, oubli contrôlé et déclenchement automatique d’une rupture de conformité en cas de modification structurelle.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/memory-governance"
      },
      "isRelatedTo": [
        {
          "@id": "https://gautierdorval.com/definitions/gouvernance-interpretative/#definedterm"
        },
        {
          "@id": "https://gautierdorval.com/defined-terms/v-layer/versioning-drift-change-control"
        },
        {
          "@id": "https://gautierdorval.com/defined-terms/v-layer/integrity-locking"
        },
        {
          "@id": "https://gautierdorval.com/defined-terms/authority-governance-layer-3"
        }
      ],
      "name": "Gouvernance de la mémoire",
      "url": "https://gautierdorval.com/doctrine/gouvernance-memoire/"
    },
    {
      "@id": "https://gautierdorval.com/defined-terms/memory-object",
      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Unité persistée, typée, versionnée et traçable représentant un énoncé ou une consolidation dans un système stateful. Un MemoryObject doit préserver l’origine (source/utilisateur/système), la temporalité, et une empreinte d’intégrité.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/memory-governance"
      },
      "name": "MemoryObject"
    },
    {
      "@id": "https://gautierdorval.com/defined-terms/consolidation-gouvernee",
      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Transformation contrôlée de plusieurs objets mémoire en un objet consolidé sous contraintes de typage, traçabilité, intégrité temporelle et journalisation append-only.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/memory-governance"
      },
      "name": "Consolidation gouvernée"
    },
    {

      ],
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Module normatif d’application visant à empêcher la fixation de variables dynamiques (prix, stock, livraison, promotions, vendeur) dans la couche interprétative sans signal de volatilité (source, horodatage, statut) et sans invalidation lors des rafraîchissements transactionnels.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/ctic"
      },
      "name": "CTIC",
      "url": "https://gautierdorval.com/frameworks/ctic/"
    },

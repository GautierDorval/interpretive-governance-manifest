    {
      "@id": "https://gautierdorval.com/definitions/gouvernance-interpretative/#definedterm",
      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Architecture environnementale visant à borner l’espace d’interprétation machine afin de réduire les inférences plausibles mais erronées. Elle agit par surfaces, hiérarchies de sources, relations canoniques et négations explicites, sans présumer d’obéissance interne du modèle.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/interpretive-governance"
      },
      "name": "Gouvernance interprétative",
      "url": "https://gautierdorval.com/definitions/gouvernance-interpretative/"
    },
    {
      "@id": "https://gautierdorval.com/defined-terms/interpretive-governance/exposure-regimes",
      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Cartographie des voies de propagation de la gouvernance interprétative selon le régime d’accès à l’environnement gouverné (direct, indirect, contextuel, différé).",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/interpretive-governance"
      },
      "name": "Régimes d’effet (exposition)"
    },
    {
      "@id": "https://gautierdorval.com/defined-terms/interpretive-governance/effect-direct",
      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Régime d’effet où le système observe activement l’environnement (crawl, moteurs de recherche, agents outillés) et peut lire ou hiérarchiser des surfaces canoniques.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/interpretive-governance"
      },
      "name": "Effet direct"
    },
    {
      "@id": "https://gautierdorval.com/defined-terms/interpretive-governance/effect-indirect",
      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Régime d’effet où le système est alimenté par des observateurs intermédiaires (RAG, index internes, connecteurs) qui fournissent des sources ou extraits.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/interpretive-governance"
      },
      "name": "Effet indirect"
    },
    {
      "@id": "https://gautierdorval.com/defined-terms/interpretive-governance/effect-contextual",
      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Régime d’effet où des artefacts gouvernés sont injectés en session (copie-coller, fichiers, prompts), rendant périmètres et exclusions disponibles au raisonnement.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/interpretive-governance"
      },
      "name": "Effet contextuel"
    },
    {
      "@id": "https://gautierdorval.com/defined-terms/interpretive-governance/effect-deferred",
      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Régime d’effet où des artefacts gouvernés sont ré-ingérés dans des cycles ultérieurs (évaluations, distillation, réentraînement), sans constituer une garantie déterministe.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/interpretive-governance"
      },
      "name": "Effet différé"
    },
    {
      "@id": "https://gautierdorval.com/defined-terms/interpretive-governance/influence",
      "@type": "DefinedTerm",
      "creator": {
        "@id": "https://gautierdorval.com/entite/#person"
      },
      "description": "Effet probabiliste résultant de la structuration de l’environnement, même sans activation opératoire explicite.",
      "inDefinedTermSet": {
        "@id": "https://gautierdorval.com/defined-terms/interpretive-governance"
      },
      "name": "Influence"
    },
    {
      "@id": "https://gautierdorval.com/defined-terms/interpretive-governance/operational-governance",

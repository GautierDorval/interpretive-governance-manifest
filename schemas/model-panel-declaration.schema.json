{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://interpretive-governance.org/schemas/model-panel-declaration.schema.json",
  "title": "Model panel declaration schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "type",
    "version",
    "models"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "https://interpretive-governance.org/schemas/model-panel-declaration.schema.json"
    },
    "type": {
      "type": "string",
      "const": "model-panel-declaration"
    },
    "version": {
      "type": "string"
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "provider",
          "model",
          "accessMode"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "accessMode": {
            "type": "string",
            "enum": [
              "api",
              "ui",
              "connector",
              "unknown"
            ]
          },
          "temperature": {
            "type": [
              "number",
              "string"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://interpretive-governance.org/schemas/causal-context-map.schema.json",
  "title": "Causal context map schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "type",
    "version",
    "status",
    "maps"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "https://interpretive-governance.org/schemas/causal-context-map.schema.json"
    },
    "type": {
      "type": "string",
      "const": "causal-context-map"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "proposed",
        "experimental",
        "stable",
        "deprecated"
      ]
    },
    "site": {
      "type": "string"
    },
    "maps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "surface",
          "meshScope",
          "trigger",
          "problemOrRisk",
          "latentNeed",
          "canonicalSurface",
          "intendedConsequence",
          "prohibitedDerivations",
          "reviewStatus"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2
          },
          "surface": {
            "type": "string",
            "minLength": 3
          },
          "meshScope": {
            "type": "string",
            "enum": [
              "doctrinal-core",
              "cluster",
              "surface",
              "candidate"
            ]
          },
          "trigger": {
            "type": "string",
            "minLength": 3
          },
          "problemOrRisk": {
            "type": "string",
            "minLength": 3
          },
          "latentNeed": {
            "type": "string",
            "minLength": 3
          },
          "canonicalSurface": {
            "type": "string",
            "minLength": 3
          },
          "intendedConsequence": {
            "type": "string",
            "minLength": 3
          },
          "prohibitedDerivations": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "reviewStatus": {
            "type": "string",
            "minLength": 3
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}

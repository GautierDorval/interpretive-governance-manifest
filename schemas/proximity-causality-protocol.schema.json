{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://interpretive-governance.org/schemas/proximity-causality-protocol.schema.json",
  "title": "Proximity-causality protocol schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "type",
    "version",
    "status",
    "purpose",
    "steps",
    "guardrails"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "https://interpretive-governance.org/schemas/proximity-causality-protocol.schema.json"
    },
    "type": {
      "type": "string",
      "const": "proximity-causality-protocol"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "proposed",
        "experimental",
        "stable",
        "deprecated"
      ]
    },
    "purpose": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "requirement"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "requirement": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
